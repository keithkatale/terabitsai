# Terabits AI — copy to apps/web/.env.local

# Supabase (from Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth via GCP (direct — not Supabase-hosted OAuth redirect)
# 1. GCP Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# 2. Authorized JavaScript origins: http://localhost:3000 and your production URL
# 3. Supabase Dashboard → Auth → Providers → Google: enable, paste same Client ID + Secret (token validation only)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Optional: server-side ledger bypass (RPC fallback works without this)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini / Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
# Recommended models (Vertex AI):
# - gemini-2.5-flash-preview-05-20 (latest, recommended)
# - gemini-2.5-flash (stable)
# - gemini-2.0-flash (fallback)
AGENT_LLM_MODEL=gemini-2.5-flash-preview-05-20

# Capital.com demo broker
CAPITAL_API_KEY=
CAPITAL_PASSWORD=
CAPITAL_IDENTIFIER=
CAPITAL_BASE_URL=https://demo-api-capital.backend-capital.com

# Market intelligence ingest (optional — enables premium diets)
FINNHUB_API_KEY=
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=
MARKETAUX_API_KEY=
FMP_API_KEY=
POLYGON_API_KEY=...               # optional Phase C

# Dodo Payments (https://docs.dodopayments.com/api-reference/introduction)
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=
DODO_PAYMENTS_ENV=test_mode
DODO_PRO_PRODUCT_ID=
DODO_PREMIUM_PRODUCT_ID=
APP_PUBLIC_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostHog analytics (https://us.posthog.com)
NEXT_PUBLIC_POSTHOG_KEY=phc_your-project-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# DataFast analytics (https://datafa.st)
NEXT_PUBLIC_DATAFAST_WEBSITE_ID=dfid_Gm4iXErEaymGfrlQMMHEh
NEXT_PUBLIC_DATAFAST_DOMAIN=terabitsai.com

# Automated Wealth Monitor (cron + wealth-manager worker). Off by default.
WEALTH_MONITOR_ENABLED=false

# Chart renderer service (Cloud Run — required for analyze_chart)
CHART_RENDER_SERVICE_URL=https://ai-agent-platform-chart-renderer-73vs3tcpga-uc.a.run.app
CHART_RENDER_API_KEY=your-shared-api-key

# Optional TradingView-TA microservice (legacy programmatic summary)
TRADINGVIEW_TA_SERVICE_URL=
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres
