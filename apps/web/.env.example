# Terabits AI — copy to apps/web/.env.local

# Supabase (from Supabase Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: server-side ledger bypass (RPC fallback works without this)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini / Vertex AI
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=us-central1
AGENT_LLM_MODEL=gemini-2.5-flash

# Capital.com demo broker
CAPITAL_API_KEY=
CAPITAL_PASSWORD=
CAPITAL_IDENTIFIER=
CAPITAL_BASE_URL=https://demo-api-capital.backend-capital.com
